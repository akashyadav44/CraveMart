# ─────────────────────────────────────────────
#  CraveMart Backend — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB — get free cluster from https://mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/cravemart?retryWrites=true&w=majority

# JWT — use a strong random secret string
JWT_SECRET=cravemart_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
 
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
